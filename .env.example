# Google Cloud OAuth client (type: Web application) — see SETUP.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Any long random string — used to sign the session cookie
SESSION_SECRET=

# Where this server is reachable. Used to build the OAuth redirect URI.
# Local dev:
BASE_URL=http://localhost:3000
# On Render, set this to your service URL instead, e.g.
# BASE_URL=https://kilometerstoliter.onrender.com

# Set by Render automatically in production; leave unset for local dev.
# NODE_ENV=production
